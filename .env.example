# SENTINEL - Smart Money Narrative Oracle

# Nansen API key (or set NANSEN_API_KEY env var)
NANSEN_API_KEY=

# Scan interval in minutes (default: 30)
SCAN_INTERVAL=30

# Chains to scan (comma-separated, default: all supported)
# CHAINS=ethereum,solana,base,arbitrum

# Max concurrent API calls
MAX_CONCURRENT=5

# Alpha brief output directory
OUTPUT_DIR=./output

# Delivery (optional)
# WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
